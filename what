def cmd_show(cmd, exit_code, output):
    """显示捕获到的命令和输出（调试用）"""
    print(f"{C.BOLD}命令:{C.RESET} {cmd}")
    print(f"{C.BOLD}退出码:{C.RESET} {exit_code}")
    print(f"{C.BOLD}输出 ({len(output)} 字符):{C.RESET}")
    print(output if output else "(无输出)")


def cmd_setup():
    """交互式配置向导"""
    os.makedirs(CONFIG_DIR, exist_ok=True)
    print(f"{C.CYAN}=== what 配置向导 ==={C.RESET}\n")

    cfg = load_config()

    api_base = input(f"API Base URL [{cfg['api_base']}]: ").strip()
    if not api_base:
        api_base = cfg["api_base"]

    api_key = input(f"API Key [{cfg['api_key'][:8] + '...' if len(cfg['api_key']) > 8 else cfg['api_key']}]: ").strip()
    if not api_key:
        api_key = cfg["api_key"]

    model = input(f"模型名称 [{cfg['model']}]: ").strip()
    if not model:
        model = cfg["model"]

    max_output_chars = input(f"最大发送输出字符数 [{cfg['max_output_chars']}]: ").strip()
    if not max_output_chars:
        max_output_chars = cfg["max_output_chars"]

    print("\n请选择你的主要使用方向:")
    print("1) 通用")
    print("2) 渗透测试/靶场")
    print("3) 开发调试")
    print("4) 运维排障")
    print("5) 自定义")
    profile_map = {
        "1": "default",
        "2": "pentest",
        "3": "dev",
        "4": "ops",
        "5": "custom",
    }
    current_profile = cfg.get("profile", "default")
    profile_choice = input(f"方向 [{current_profile}]: ").strip()
    profile = profile_map.get(profile_choice, profile_choice or current_profile)
    if profile not in PROFILE_PROMPTS:
        print(f"{C.YELLOW}未识别的方向，使用 default{C.RESET}")
        profile = "default"

    custom_instruction = cfg.get("custom_instruction", "")
    if profile == "custom" or input("是否添加自定义分析偏好? [y/N] ").strip().lower() in ("y", "yes"):
        entered = input("自定义分析偏好: ").strip()
        custom_instruction = entered or custom_instruction

    with open(CONFIG_FILE, "w") as f:
        f.write(f"# what 配置文件\n")
        f.write(f"# 支持 OpenAI 兼容的 API（OpenAI、DeepSeek、Ollama 等）\n\n")
        f.write(f"api_base = {api_base}\n")
        f.write(f"api_key = {api_key}\n")
        f.write(f"model = {model}\n")
        f.write(f"max_output_chars = {max_output_chars}\n")
        f.write(f"profile = {profile}\n")
        f.write(f"custom_instruction = {custom_instruction}\n")

    print(f"\n{C.GREEN}配置已保存到 {CONFIG_FILE}{C.RESET}")


def parse_args(argv=None):
    parser = argparse.ArgumentParser(
        prog="what",
        description="分析终端命令的执行结果（自动捕获上一条命令）",
        epilog="""示例:
  what                              分析上一条命令（默认 Markdown 非流式）
  what -q "这个错误怎么修"            带自定义问题（推荐）
  what --show                       查看捕获到的原始信息
  what --smart                      启用智能缩减后再发送给 LLM
  what --stream                     流式纯文本输出
  what --cmd 'ls -la /' --output-file /tmp/out.txt --exit-code 0  手动测试""",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("rest", nargs="*", help=argparse.SUPPRESS)  # 向后兼容
    parser.add_argument("-q", "--question", help="自定义问题（推荐，用引号包裹）")
    parser.add_argument("--show", action="store_true", help="查看捕获到的命令和输出（不调用 LLM）")
    parser.add_argument("--setup", action="store_true", help="交互式配置向导")
    parser.add_argument("--no-color", action="store_true", help="禁用彩色输出")
    parser.add_argument("--smart", action="store_true", help="启用智能缩减，只发送提炼后的关键输出")
    parser.add_argument("--raw", action="store_true", help="兼容旧参数：当前默认就是发送完整输出")
    parser.add_argument("--md", action="store_true", help="兼容旧参数：当前默认就是 Markdown 渲染")
    parser.add_argument("--plain", action="store_true", help="纯文本输出，禁用 Markdown 渲染")
    parser.add_argument("--stream", action="store_true", help="流式纯文本输出")
    parser.add_argument("-d", "--debug", action="store_true", help="调试模式：日志同步输出到 stderr")
    # 测试模式（无需安装 hook）
    parser.add_argument("--cmd", help="手动指定命令文本（测试用，无需 hook）")
    parser.add_argument("--output", help="手动指定命令输出文本（测试用）")
    parser.add_argument("--output-file", help="从文件读取命令输出（测试用）")
    parser.add_argument("--exit-code", default="0", help="手动指定退出码（测试用，默认 0）")
    return parser.parse_args(argv)


def main():
    args = parse_args()

    global _DEBUG
    _DEBUG = args.debug

    if _DEBUG:
        log("=== what 启动 ===")

    if args.no_color:
        C.off()

    # ── 配置向导 ──
    if args.setup:
        cmd_setup()
        return

    # ── 加载配置 ──
    cfg = load_config()
    log(f"配置: model={cfg['model']}, base={cfg['api_base']}, "
        f"profile={cfg.get('profile', 'default')}, "
        f"key={'已设置' if cfg.get('api_key') else '未设置'}")

    # ── 获取命令信息：手动测试模式 vs 自动捕获模式 ──
    manual_mode = bool(args.cmd or args.output or args.output_file)
    if manual_mode:
        cmd = args.cmd or "(手动指定)"
        exit_code = args.exit_code
        log(f"手动模式: cmd={cmd}, exit_code={exit_code}")
        if args.output_file:
            with open(args.output_file) as f:
                raw = f.read()
            output = strip_ansi(raw).strip()
        elif args.output:
            output = args.output
        else:
            output = ""
        log(f"手动模式输出: {len(output)} 字符")
    else:
        cmd, exit_code, output = get_last_command_info()
        if not cmd:
            log("未找到上一条命令，退出", "ERROR")
            print(f"{C.RED}未找到上一条命令。{C.RESET}", file=sys.stderr)
            print("请确保已在 shell 中加载 what-hook.sh", file=sys.stderr)
            print("", file=sys.stderr)
            print("或者使用手动测试模式:", file=sys.stderr)
            print("  what --cmd '你的命令' --output '命令的输出' --exit-code 1", file=sys.stderr)
            sys.exit(1)

    # ── 查看模式 ──
    if args.show:
        cmd_show(cmd, exit_code, output)
        return

    # ── 检查 API Key ──
    if not cfg.get("api_key"):
        print(f"{C.RED}未配置 API Key。{C.RESET}", file=sys.stderr)
        print(f"请运行 what --setup 进行配置，或设置环境变量 WHAT_API_KEY", file=sys.stderr)
        sys.exit(1)

    # ── 构建提示 ──
    user_question = args.question or (" ".join(args.rest) if args.rest else None)
    use_smart = args.smart
    system_prompt, user_prompt = build_prompt(
        cmd, exit_code, output, user_question, use_smart, cfg
    )

    # ── 显示分析头 ──
    print(f"\n{C.DIM}{'─' * 50}{C.RESET}")
    print(f"{C.CYAN}$ {cmd}{C.RESET}  {C.DIM}(exit: {exit_code}){C.RESET}")
    if use_smart and len(output) > 6000:
        print(f"{C.DIM}(原始 {len(output)} 字符，智能缩减后 prompt ~{len(user_prompt)} 字符){C.RESET}")
    elif not use_smart and len(output) > _max_output_chars(cfg):
        print(f"{C.DIM}(原始 {len(output)} 字符，按 max_output_chars 保留头尾){C.RESET}")
    print(f"{C.DIM}{'─' * 50}{C.RESET}\n")

    # ── 调用 LLM ──
    if args.stream:
        stream_llm(cfg, system_prompt, user_prompt)
    else:
        text = call_llm_nonstream(cfg, system_prompt, user_prompt)
        if args.plain:
            print(text)
        else:
            render_markdown(text)
    print()

    log("完成")


if __name__ == "__main__":
    main()
