# Prompt 构建 — 根据输出内容自适应调整
# ══════════════════════════════════════════════════════════════

def build_prompt(cmd, exit_code, raw_output, user_question=None, use_smart=False, cfg=None):
    """构建发送给 LLM 的 system/user prompt。"""
    cfg = cfg or DEFAULTS
    output, summary, meta = prepare_output(raw_output, cfg, use_smart)
    result_type = classify_result(exit_code, summary)
    system = build_system_prompt(cfg)
    prompt = build_user_prompt(
        cmd, exit_code, output, result_type, summary, meta, user_question, cfg
    )
    return system, prompt


def _api_request(cfg, system_prompt, user_prompt, stream=True):
    """发送 API 请求，返回 response 对象"""
    api_base = cfg["api_base"].rstrip("/")
    url = f"{api_base}/chat/completions"

    payload = json.dumps({
        "model": cfg["model"],
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_prompt},
        ],
        "stream": stream,
    }).encode("utf-8")

    log(f"API 请求: model={cfg['model']}, endpoint={api_base}, "
        f"prompt_size={len(user_prompt)}chars, stream={stream}")

    req = Request(url, data=payload, headers={
        "Content-Type": "application/json",
        "Authorization": f"Bearer {cfg['api_key']}",
    })

    try:
        return urlopen(req, timeout=60)
    except HTTPError as e:
        body = e.read().decode("utf-8", errors="replace")
        log(f"API HTTP {e.code}: {body[:500]}", "ERROR")
        print(f"\n{C.RED}API 错误 ({e.code}):{C.RESET} {body}", file=sys.stderr)
        sys.exit(1)
    except URLError as e:
        log(f"API 连接失败: {e.reason}", "ERROR")
        print(f"\n{C.RED}连接失败:{C.RESET} {e.reason}", file=sys.stderr)
        print(f"请检查 api_base 配置: {cfg['api_base']}", file=sys.stderr)
        sys.exit(1)


def stream_llm(cfg, system_prompt, user_prompt):
    """流式输出 API 响应，返回完整文本"""
    resp = _api_request(cfg, system_prompt, user_prompt, stream=True)

    buffer = ""
    for raw_line in resp:
        line = raw_line.decode("utf-8", errors="replace").strip()
        if not line.startswith("data: "):
            continue
        data = line[6:]
        if data == "[DONE]":
            break
        try:
            chunk = json.loads(data)
            delta = chunk["choices"][0].get("delta", {})
            content = delta.get("content", "")
            if content:
                print(content, end="", flush=True)
                buffer += content
        except (json.JSONDecodeError, KeyError, IndexError):
            continue

    print()
    resp.close()
    log(f"流式响应完成: {len(buffer)} 字符")
    llm_log(system_prompt, user_prompt, buffer)
    return buffer


def call_llm_nonstream(cfg, system_prompt, user_prompt):
    """非流式调用 API，返回完整响应文本"""
    resp = _api_request(cfg, system_prompt, user_prompt, stream=False)

    body = resp.read().decode("utf-8", errors="replace")
    resp.close()

    try:
        data = json.loads(body)
        text = data["choices"][0]["message"]["content"]
        log(f"非流式响应完成: {len(text)} 字符")
        llm_log(system_prompt, user_prompt, text)
        return text
    except (json.JSONDecodeError, KeyError, IndexError) as e:
        log(f"解析 API 响应失败: {body[:500]}", "ERROR")
        print(f"\n{C.RED}解析响应失败:{C.RESET} {body[:500]}", file=sys.stderr)
        sys.exit(1)


def render_markdown(text):
    """用 rich 库渲染 Markdown 到终端"""
    try:
        from rich.console import Console
        from rich.markdown import Markdown
        console = Console()
        md = Markdown(text)
        console.print(md)
    except ImportError:
        print(f"{C.YELLOW}提示: 安装 rich 库以获得 Markdown 渲染效果:{C.RESET}")
        print("  pip install rich")
        print("")
        print(text)


