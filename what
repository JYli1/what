# 智能输出提炼 — 本地提取关键信息，减少发给 LLM 的 token
# ══════════════════════════════════════════════════════════════

# 需要捕获的关键行模式
ERROR_PATTERNS = [
    # 通用错误
    r'(?i)\berr(?:or)?\b',          # error / err
    r'(?i)\bfatal\b', r'(?i)\bpanic\b',
    r'(?i)\bfail(?:ed|ure)?\b', r'(?i)\bexception\b',
    r'(?i)\binvalid\b', r'(?i)\bunknown\b',
    r'(?i)\b(?:permission\s+)?denied\b', r'(?i)\bnot\s+found\b',
    r'(?i)\btime\s*out\b', r'(?i)\brefused\b',
    r'(?i)\bcannot\b', r'(?i)\bcould\s+not\b',
    r'(?i)\bunrecogni[sz]ed\b', r'(?i)\bmissing\b',
    r'(?i)\brequired\b', r'(?i)\bunexpected\b',
    r'(?i)\bwrong\b', r'(?i)\bunable\s+to\b',
    # 连接相关
    r'(?i)\bconnection\s+(?:refused|reset|closed|timed?\s*out)\b',
    r'(?i)\bconnect\b', r'(?i)\bdisconnect(?:ed)?\b',
    # 系统级
    r'(?i)\bseg(?:mentation)?\s+fault\b',
    r'(?i)\bbus\s+error\b', r'(?i)\bcore\s+dumped\b',
    r'(?i)\btraceback\b', r'(?i)\bbacktrace\b',
    r'(?i)\bsignal\b', r'(?i)\bkilled\b', r'(?i)\babort(?:ed)?\b',
    r'(?i)\bout\s+of\s+memory\b', r'(?i)\boom\b',
    # 命令/文件
    r'(?i)\bno\s+such\s+file\b',
    r'(?i)\bcommand\s+not\s+found\b',
    r'(?i)\bsyntax\s+error\b', r'(?i)\bparse\s+error\b',
    r'(?i)\bname\s+error\b', r'(?i)\btype\s+error\b',
    # 中文错误
    r'错误', r'失败', r'异常', r'禁止', r'拒绝',
    r'未找到', r'找不到', r'超时', r'无权限',
]

TIP_PATTERNS = [
    r'(?i)\btip\b', r'(?i)\bhint\b', r'(?i)\bsuggestion\b',
    r'(?i)\bdid\s+you\s+mean\b', r'(?i)\bto\s+pass\b',
    r'(?i)\bfor\s+more\s+information\b',
    r'(?i)\bsee\b', r'(?i)\brefer\b',
    # 中文提示
    r'提示', r'建议', r'用法', r'试试', r'请参考',
]

WARNING_PATTERNS = [
    r'(?i)\bwarn(?:ing)?\b', r'(?i)\bdeprecated\b',
    r'(?i)\bnotice\b', r'(?i)\bcaution\b',
    r'(?i)\bnote\b', r'(?i)\bwill\s+be\s+removed\b',
    # 中文警告
    r'警告', r'注意', r'已弃用', r'将移除',
]

USAGE_PATTERNS = [
    r'(?i)^\s*usage\s*:', r'(?i)^\s*用法\s*[：:]',
]


def _match_any(line, patterns):
    """检查行是否匹配任意模式"""
    for pat in patterns:
        if re.search(pat, line):
            return True
    return False


def smart_extract(output, max_chars=6000):
    """
    从命令输出中智能提取，保留关键信息的同时尽量不丢失细节。
    返回 (extracted_text, summary_dict)

    策略（从激进改为均衡）：
    1. 短输出 (< max_chars) → 完整返回
    2. 错误行 → 全部保留，带 ±2 行上下文
    3. 非错误行 → 均匀采样，保留中间的代表性内容
    4. 头部和尾部 → 各保留更多行
    """
    if len(output) <= max_chars:
        return output, None

    lines = output.split('\n')
    total_lines = len(lines)
    total_chars = len(output)

    while lines and not lines[-1].strip():
        lines.pop()

    head_count = 20
    tail_count = 15
    ctx_radius = 2  # 错误行上下文半径

    # ── 分类：标记哪些行需要保留 ──
    keep = set()

    # 头部和尾部始终保留
    for i in range(min(head_count, len(lines))):
        keep.add(i)
    for i in range(max(0, len(lines) - tail_count), len(lines)):
        keep.add(i)

    error_lines = []
    tip_lines = []
    warning_lines = []
    usage_lines = []
    middle_range = range(head_count, len(lines) - tail_count) if len(lines) > head_count + tail_count else range(0, 0)

    for i in middle_range:
        stripped = lines[i].strip()
        if not stripped:
            continue

        if _match_any(stripped, ERROR_PATTERNS):
            error_lines.append((i, stripped))
            # 保留上下文
            for j in range(max(0, i - ctx_radius), min(len(lines), i + ctx_radius + 1)):
                keep.add(j)
        elif _match_any(stripped, TIP_PATTERNS):
            tip_lines.append((i, stripped))
            keep.add(i)
        elif _match_any(stripped, WARNING_PATTERNS):
            warning_lines.append((i, stripped))
            keep.add(i)
        elif _match_any(stripped, USAGE_PATTERNS):
            usage_lines.append((i, stripped))

    # ── 均衡采样：中间非关键行也保留一部分 ──
    # 取中间区域中未被 keep 的行，均匀采样
    unsampled = [i for i in middle_range if i not in keep]
    if unsampled:
        # 采样率：保留约 50 行代表性内容
        sample_rate = max(1, len(unsampled) // 50)
        for idx, line_idx in enumerate(unsampled):
            if idx % sample_rate == 0:
                keep.add(line_idx)

    # ── 按行号排序构建输出 ──
    kept_lines = []
    last_idx = -2
    for i in sorted(keep):
        if i > last_idx + 1:
            kept_lines.append(f";;; [跳过 {i - last_idx - 1} 行]")
        kept_lines.append(lines[i])
        last_idx = i

    # 去重（Usage 行通常很多重复）
    if usage_lines and len(usage_lines) > 3:
        kept_lines = _dedup_usage(kept_lines)

    extracted = '\n'.join(kept_lines)

    # 最终截断保护
    if len(extracted) > max_chars + 2000:
        extracted = extracted[:max_chars] + '\n;;; [已截断]'

    summary = {
        'total_lines': total_lines,
        'total_chars': total_chars,
        'kept_lines': len(keep),
        'error_count': len(error_lines),
        'warning_count': len(warning_lines),
        'has_tips': len(tip_lines) > 0,
        'sampled': len(unsampled) > 0,
    }

    return extracted, summary


def _dedup_usage(lines):
    """去除连续重复行（usage/help 常见）"""
    result = []
    prev = None
    streak = 0
    for line in lines:
        if line == prev:
            streak += 1
            if streak == 3:
                result.append(';;; [重复行已省略]')
            elif streak < 3:
                result.append(line)
        else:
            streak = 0
            prev = line
            result.append(line)
    return result


def truncate_output(output, max_chars):
    """按字符上限保留头尾，返回总长度不超过 max_chars 的文本。"""
    if max_chars <= 0 or len(output) <= max_chars:
        return output

    marker = f"\n;;; [中间超出 {max_chars} 字符上限，已截断]\n"
    if len(marker) >= max_chars:
        return output[:max_chars]

    available = max_chars - len(marker)
    head_len = available // 2
    tail_len = available - head_len
    return output[:head_len] + marker + output[-tail_len:]


def _max_output_chars(cfg):
    try:
        return int(cfg.get("max_output_chars", DEFAULTS["max_output_chars"]))
    except (TypeError, ValueError):
        return int(DEFAULTS["max_output_chars"])


def build_system_prompt(cfg):
    """根据配置中的工作方向生成 system prompt。"""
    profile = cfg.get("profile", "default").strip().lower() or "default"
    return PROFILE_PROMPTS.get(profile, PROFILE_PROMPTS["default"])


def prepare_output(raw_output, cfg, use_smart=False):
    """准备要发送给 LLM 的输出，并返回处理元数据。"""
    raw_output = raw_output or ""
    original_chars = len(raw_output)

    if use_smart and raw_output:
        output, summary = smart_extract(raw_output)
        return output, summary, {
            "mode": "smart",
            "label": "智能缩减",
            "original_chars": original_chars,
            "sent_chars": len(output),
        }

    max_chars = _max_output_chars(cfg)
    output = truncate_output(raw_output, max_chars)
    mode = "truncated" if len(output) < original_chars else "full"
    label = "已截断，保留头尾" if mode == "truncated" else "完整输出"
    return output, None, {
        "mode": mode,
        "label": label,
        "original_chars": original_chars,
        "sent_chars": len(output),
    }


def classify_result(exit_code, summary):
    """根据退出码和智能缩减摘要判断结果类型。"""
    exit_success = (exit_code == "0")
    if not exit_success and summary and summary.get("error_count", 0) > 0:
        return "失败且检测到错误"
    if not exit_success:
        return "失败"
    if summary and summary.get("warning_count", 0) > 0:
        return "成功但有警告"
    return "成功"


def build_sample_note(summary):
    """生成人类可读的智能缩减说明。"""
    if not summary:
        return ""
    parts = [
        f"原始 {summary['total_lines']} 行 / {summary['total_chars']} 字符",
        f"保留 {summary['kept_lines']} 行",
        f"错误 {summary['error_count']} 条",
        f"警告 {summary['warning_count']} 条",
    ]
    if summary.get("sampled"):
        parts.append("包含均匀采样")
    return "；".join(parts)


def build_answer_requirements(cfg, result_type):
    """根据 profile 和结果类型生成回答要求。"""
    requirements = [
        "先用一句话说明结论",
        "列出关键发现",
        "给出下一步建议",
    ]

    if result_type.startswith("失败"):
        requirements.append("如果能修复，给出最短可执行修复命令")
    elif result_type == "成功但有警告":
        requirements.append("说明警告是否需要处理")

    if cfg.get("profile", "default").strip().lower() == "pentest":
        requirements.append("给出下一步枚举/验证命令，并提醒仅限授权环境")

    custom_instruction = cfg.get("custom_instruction", "").strip()
    if custom_instruction:
        requirements.append(f"用户偏好: {custom_instruction}")

    return requirements


def build_user_prompt(cmd, exit_code, output, result_type, summary, meta, user_question, cfg):
    """构建结构化 user prompt。"""
    output_text = output if output else "(无输出)"
    lines = [
        "请分析这条终端命令的结果。",
        "",
        "上下文:",
        f"- 命令: `{cmd}`",
        f"- 退出码: {exit_code}",
        f"- 结果类型: {result_type}",
        f"- 输出处理: {meta['label']} ({meta['sent_chars']}/{meta['original_chars']} 字符)",
    ]

    sample_note = build_sample_note(summary)
    if sample_note:
        lines.append(f"- 智能缩减摘要: {sample_note}")

    if user_question:
        lines.append(f"- 用户追问: {user_question}")

    lines.extend([
        "",
        "命令输出:",
        "```text",
        output_text,
        "```",
        "",
        "请按以下要求回答:",
    ])

    for index, requirement in enumerate(build_answer_requirements(cfg, result_type), 1):
        lines.append(f"{index}. {requirement}")

    return "\n".join(lines)


