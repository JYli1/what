OUTPUT_START_FILE = os.path.join(CONFIG_DIR, "output_start")
OUTPUT_END_FILE = os.path.join(CONFIG_DIR, "output_end")
LOG_FILE = os.path.join(CONFIG_DIR, "what.log")
LLM_LOG_FILE = os.path.join(CONFIG_DIR, "llm.log")
LOG_MAX_BYTES = 100 * 1024  # 100KB

IS_WINDOWS = platform.system() == "Windows"
if IS_WINDOWS:
    OUTPUT_FILE = os.path.join(CONFIG_DIR, "output.txt")
else:
    OUTPUT_FILE = None

# ── 默认配置 ──
DEFAULTS = {
    "api_key": "",
