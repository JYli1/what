# ── 路径常量 ──
CONFIG_DIR = os.path.expanduser("~/.what")
CONFIG_FILE = os.path.join(CONFIG_DIR, "config")
SESSION_LOG = os.path.join(CONFIG_DIR, "session.log")
LAST_CMD_FILE = os.path.join(CONFIG_DIR, "last_cmd")
