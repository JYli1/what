_DEBUG = False  # --debug 标志

# ── 颜色 ──
class C:
    BOLD   = "\033[1m"
    DIM    = "\033[2m"
    GREEN  = "\033[32m"
    YELLOW = "\033[33m"
    RED    = "\033[31m"
    CYAN   = "\033[36m"
    RESET  = "\033[0m"

    @staticmethod
    def off():
        for attr in ("BOLD", "DIM", "GREEN", "YELLOW", "RED", "CYAN", "RESET"):
            setattr(C, attr, "")


def log(msg, level="INFO"):
    """写日志到 ~/.what/what.log，-d/--debug 时同步输出到 stderr"""
    global _DEBUG
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{timestamp}] [{level}] {msg}"
    try:
        os.makedirs(CONFIG_DIR, exist_ok=True)
        # 简单轮转：超过上限则截半
        if os.path.exists(LOG_FILE) and os.path.getsize(LOG_FILE) > LOG_MAX_BYTES:
            with open(LOG_FILE, "r", errors="replace") as f:
                old = f.read()
            with open(LOG_FILE, "w") as f:
                f.write(old[-LOG_MAX_BYTES // 2:])
        with open(LOG_FILE, "a") as f:
            f.write(line + "\n")
    except (IOError, OSError):
        pass
    if _DEBUG:
        print(f"{C.DIM}[d]{C.RESET} {line}", file=sys.stderr)


def llm_log(system_prompt, user_prompt, response):
    """记录每次 LLM 对话的完整 prompt 和 response 到 ~/.what/llm.log"""
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    sep = "=" * 60
    entry = f"""{sep}
[{timestamp}] LLM 对话记录
{sep}
>>> SYSTEM:
{system_prompt}

>>> USER:
{user_prompt}

<<< RESPONSE ({len(response)} 字符):
{response}
{sep}
"""
    try:
        os.makedirs(CONFIG_DIR, exist_ok=True)
        if os.path.exists(LLM_LOG_FILE) and os.path.getsize(LLM_LOG_FILE) > LOG_MAX_BYTES:
            with open(LLM_LOG_FILE, "r", errors="replace") as f:
                old = f.read()
            with open(LLM_LOG_FILE, "w") as f:
                f.write(old[-LOG_MAX_BYTES // 2:])
        with open(LLM_LOG_FILE, "a") as f:
            f.write(entry)
    except (IOError, OSError):
        pass


def load_config():
    """加载配置：文件 → 环境变量覆盖"""
    cfg = dict(DEFAULTS)

    if os.path.exists(CONFIG_FILE):
        with open(CONFIG_FILE) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                if "=" in line:
                    k, v = line.split("=", 1)
                    cfg[k.strip().lower()] = v.strip()

    for key in list(cfg.keys()):
        env_val = os.environ.get(f"WHAT_{key.upper()}")
        if env_val:
            cfg[key] = env_val

    return cfg


def strip_ansi(text):
    """去除 ANSI 转义序列和终端控制字符"""
    text = re.sub(r'\x1b\[[0-9;]*[a-zA-Z]', '', text)
    text = re.sub(r'\x1b\][^\x07]*\x07', '', text)
    text = re.sub(r'\x1b[()][AB012]', '', text)
    text = re.sub(r'\x1b[\[\]()#;?]*[0-9;]*[a-zA-Z]', '', text)
    text = text.replace('\r\n', '\n').replace('\r', '')
    text = re.sub(r'[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]', '', text)
    return text


def read_file(path):
    """安全读取文件内容"""
    try:
        with open(path) as f:
            return f.read().strip()
    except (IOError, OSError):
        return ""


def get_last_command_info():
    """读取上一条命令、退出码和输出"""
    cmd = read_file(LAST_CMD_FILE)
    exit_code = read_file(LAST_EXIT_FILE) or "unknown"

    log(f"读取命令: cmd={cmd[:200] if cmd else '(空)'}, exit={exit_code}")

    output = ""
    if IS_WINDOWS:
        output = read_file(OUTPUT_FILE)
        if output:
            output = strip_ansi(output).strip()
        log(f"读取输出 (Windows): {len(output)} 字符")
    else:
        start_str = read_file(OUTPUT_START_FILE)
        end_str = read_file(OUTPUT_END_FILE)

        if start_str and end_str:
            try:
                start = int(start_str)
                end = int(end_str)
                if os.path.exists(SESSION_LOG) and end > start:
                    with open(SESSION_LOG, "rb") as f:
                        f.seek(start)
                        raw = f.read(end - start)
                    output = strip_ansi(raw.decode("utf-8", errors="replace"))
                    output = output.strip()
                    log(f"读取输出: {len(output)} 字符 (offset {start}-{end})")
                elif os.path.exists(SESSION_LOG) and end == start:
                    session_size = os.path.getsize(SESSION_LOG)
                    if session_size <= start:
                        output = (
                            "[what 诊断] session.log 未增长，未捕获到命令输出。\n"
                            "请重新打开终端，或执行: unset __WHAT_RECORDING; source ~/.what/what-hook.sh"
                        )
                        log(
                            f"session.log 未增长: start={start}, end={end}, size={session_size}",
                            "WARN",
                        )
                    else:
                        with open(SESSION_LOG, "rb") as f:
                            f.seek(start)
                            raw = f.read(session_size - start)
                        output = strip_ansi(raw.decode("utf-8", errors="replace")).strip()
                        log(
                            f"output_end 未更新，回退读取到文件末尾: {len(output)} 字符 "
                            f"(offset {start}-{session_size})",
                            "WARN",
                        )
                else:
                    log(f"session.log 不可用: start={start_str}, end={end_str}", "WARN")
            except (ValueError, IOError, OSError) as e:
                log(f"读取输出异常: {e}", "ERROR")
        else:
            log(f"output_start/end 为空: start={start_str}, end={end_str}", "WARN")

    if not cmd:
        log("命令为空 — hook 可能未加载", "WARN")

    return cmd, exit_code, output


